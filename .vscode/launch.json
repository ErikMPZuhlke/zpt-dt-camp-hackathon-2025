{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug Backend",
            "type": "debugpy",
            "request": "attach",
            "preLaunchTask": "docker-compose: up debug",
            "connect": {
                "host": "localhost",
                "port": 5678
            },
            "pathMappings": [
                {
                    "localRoot": "${workspaceFolder}/src/backend",
                    "remoteRoot": "/app"
                }
            ],
            "justMyCode": false
        },
        {
            "name": "Debug Frontend",
            "type": "debugpy",
            "request": "attach",
            "preLaunchTask": "docker-compose: up debug",
            "connect": {
                "host": "localhost",
                "port": 5679
            },
            "pathMappings": [
                {
                    "localRoot": "${workspaceFolder}/src/frontend",
                    "remoteRoot": "/app"
                }
            ],
            "justMyCode": false
        }
    ],
    "compounds": [
        {
            "name": "Debug Full Stack",
            "configurations": [
                "Debug Backend",
                "Debug Frontend"
            ],
            "preLaunchTask": "docker-compose: up debug",
            "presentation": {
                "group": "Full Stack Debug",
                "order": 1
            }
        }
    ]
}